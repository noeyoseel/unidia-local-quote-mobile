# MySQL connection string. Railway's MySQL plugin fills this in automatically
# when you add it to the same project.
DATABASE_URL=mysql://user:password@host:3306/database

# Any long random string. Used to sign login session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Anthropic API key (https://console.anthropic.com/) — used for the
# AI inquiry-capture image extraction step (Claude Haiku).
ANTHROPIC_API_KEY=

# The only two accounts allowed to log in.
AUTH_USER_1_EMAIL=
AUTH_USER_1_PASSWORD=
AUTH_USER_2_EMAIL=
AUTH_USER_2_PASSWORD=

# Leave empty for a normal single-domain deploy (web and API share the same
# Railway URL, so the web build calls the API on the current origin). Only
# set this if you deploy the frontend and backend to different domains.
EXPO_PUBLIC_API_BASE_URL=

# Standard Node env flag. Railway sets this to "production" automatically
# in production deploys; leave unset for local dev.
NODE_ENV=
